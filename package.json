{
  "name": "@oakoliver/bubbles",
  "version": "1.0.0",
  "description": "Pre-built TUI components for TypeScript — zero-dependency port of Charmbracelet's Bubbles",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build:esm": "esbuild src/index.ts --bundle --format=esm --platform=node --outfile=dist/index.js --target=esnext --external:@oakoliver/lipgloss --external:@oakoliver/bubbletea",
    "build:cjs": "esbuild src/index.ts --bundle --format=cjs --platform=node --outfile=dist/index.cjs --target=esnext --external:@oakoliver/lipgloss --external:@oakoliver/bubbletea",
    "build:types": "tsc --emitDeclarationOnly",
    "build": "npm run build:esm && npm run build:cjs && npm run build:types",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "tui",
    "terminal",
    "ui",
    "components",
    "bubbles",
    "charmbracelet",
    "spinner",
    "textinput",
    "textarea",
    "table",
    "viewport",
    "progress",
    "list",
    "filepicker",
    "cli",
    "typescript"
  ],
  "author": "Antonio Oliveira <antonio@oakoliver.com> (https://oakoliver.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oakoliver/bubbles"
  },
  "homepage": "https://github.com/oakoliver/bubbles#readme",
  "bugs": {
    "url": "https://github.com/oakoliver/bubbles/issues"
  },
  "peerDependencies": {
    "@oakoliver/lipgloss": "^1.0.0",
    "@oakoliver/bubbletea": "^1.0.0"
  },
  "devDependencies": {
    "@oakoliver/lipgloss": "^1.0.0",
    "@oakoliver/bubbletea": "^1.0.0",
    "@types/node": "^20",
    "esbuild": "^0.27.4",
    "typescript": "^5"
  }
}
